<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center">
    <div class="bg-white p-8 rounded-lg shadow-md w-full max-w-md">
        <a href="<%= user.role === 'vendor' ? '/products/dashboard' : '/products' %>" 
            class="text-indigo-600 hover:text-indigo-800 mb-4 inline-block">
        &larr; Back to <%= user.role === 'vendor' ? 'Vendor Dashboard' : 'Products' %>
        </a>

        <h1 class="text-2xl font-bold mb-6 text-center text-gray-800">Your Profile</h1>

        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700">Username</label>
            <div class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50">
                <%= user.username %>
            </div>
        </div>

        <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700">Email</label>
            <div class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50">
                <%= user.email %>
            </div>
        </div>

        <% if (user.role === 'customer') { %>
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700">Shipping Address</label>
                <div class="mt-1 px-3 py-2 border border-gray-300 rounded-md bg-gray-50 min-h-[42px]">
                    <%= user.shippingAddress || '' %>
                </div>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700">Region</label>
                <div class="mt-1 px-3 py-2 border border-gray-300 rounded-md bg-gray-50 min-h-[42px]">
                    <%= user.region || '' %>
                </div>
            </div>
        <% } %>

        <% if (user.role === 'vendor') { %>
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700">Business Name</label>
                <div class="mt-1 px-3 py-2 border border-gray-300 rounded-md bg-gray-50 min-h-[42px]">
                    <%= user.businessName || '' %>
                </div>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700">Store Address</label>
                <div class="mt-1 px-3 py-2 border border-gray-300 rounded-md bg-gray-50 min-h-[42px]">
                    <%= user.storeAddress || '' %>
                </div>
            </div>
        <% } %>

        <div class="flex justify-between items-center">
            <a href="/profile/edit" class="text-indigo-600 hover:text-indigo-500 font-medium">
                Edit Account Details
            </a>

            <form action="/logout" method="POST">
                <button type="submit" class="text-red-600 hover:text-red-500 font-medium">
                    Logout
                </button>
            </form>
        </div>
    </div>
</body>
</html>
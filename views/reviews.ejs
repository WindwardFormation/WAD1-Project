<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reviews</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-100 min-h-screen">
    <div class="container mx-auto px-4 py-8">
        <a href="/products" class="text-indigo-600 hover:text-indigo-800 mb-4 inline-block">&larr; Back to Products</a>
        <h1 class="text-3xl font-bold mb-8">My Reviews</h1>

        <div class="flex border-b mb-6">
            <a href="/reviews?tab=toreview"
               class="px-4 py-2 font-medium <%= tab === 'toreview' ? 'border-b-2 border-indigo-600 text-indigo-600' : 'text-gray-600 hover:text-indigo-600' %>">
                To Review
            </a>

            <a href="/reviews?tab=history"
               class="px-4 py-2 font-medium <%= tab === 'history' ? 'border-b-2 border-indigo-600 text-indigo-600' : 'text-gray-600 hover:text-indigo-600' %>">
                History
            </a>
        </div>


        <% if (tab === 'toreview') { %>
            <% if (!toReviewItems || toReviewItems.length === 0) { %>
                <div class="bg-white p-6 rounded-lg shadow-md">
                    <p class="text-gray-600">No completed orders available for review.</p>
                </div>
            <% } %>

            <% toReviewItems.forEach(item => { %>
                <div class="bg-white p-6 rounded-lg shadow-md mb-6">
                    <h2 class="text-xl font-semibold mb-2">
                        <i class="fa-solid fa-shop mr-2"></i><%= item.vendorName %>
                    </h2>

                    <p class="text-gray-700 mb-2">Order ID: <%= item.orderId %></p>
                    <p class="text-gray-700 mb-2">Product Name: <%= item.productName %></p>
                    <p class="text-gray-700 mb-2">Quantity: <%= item.quantity %></p>
                    <p class="text-gray-700 mb-2">
                        Total: $<%= item.quantity * item.price %>
                    </p>

                    <a href="/products/<%= item.productId %>" class="bg-indigo-500 text-white px-4 py-2 rounded hover:bg-indigo-600 inline-block">
                        Rate
                    </a>
                </div>
            <% }); %>
        <% } %>

        <% if (tab === 'history') { %>
            <% if (!historyItems || historyItems.length === 0) { %>
                <div class="bg-white p-6 rounded-lg shadow-md">
                    <p class="text-gray-600">No review history yet.</p>
                </div>
            <% } %>

            <% historyItems.forEach(item => { %>
                <div class="bg-white p-6 rounded-lg shadow-md mb-6">
                    <h2 class="text-xl font-semibold mb-2">
                        <i class="fa-solid fa-shop mr-2"></i><%= item.vendorName %>
                    </h2>

                    <p class="text-gray-700 mb-2">Product Name: <%= item.productName %></p>
                    <p class="text-yellow-500 mb-2">
                        <%= '★'.repeat(item.rating) %> (<%= item.rating %>/5)
                    </p>
                    <p class="text-gray-700 mb-2"><%= item.comment %></p>
                    <p class="text-sm text-gray-500"><%= item.createdAt.toDateString() %></p>

                    <br>
                    <a href="/products/<%= item.productId %>" class="bg-indigo-500 text-white px-4 py-2 rounded hover:bg-indigo-600 inline-block">
                        Edit
                    </a>

                </div>
            <% }); %>
        <% } %>
    </div>
</body>
</html>
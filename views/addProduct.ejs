
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen flex items-center justify-center">

<div class="bg-white p-8 rounded-lg shadow-md w-full max-w-md">

    <a href="/vendor/dashboard" class="text-indigo-600 hover:text-indigo-800 mb-4 inline-block">
        &larr; Back to Dashboard
    </a>

    <h1 class="text-2xl font-bold mb-6 text-center">Add New Product</h1>
    <% if (errors && errors.general) { %>
        <p class="text-red-500 mb-4 text-center"><%= errors.general %></p>
    <% } %>

    <form action="/vendor/add" method="POST" class="space-y-4">
        <div>
            <label class="block text-sm font-medium text-gray-700">Name:</label>
            <input 
                type="text" 
                name="name" 
                value="<%= old?.name || '' %>"
                class="mt-1 block w-full px-3 py-2 border rounded-md shadow-sm focus:outline-none 
                <%= errors?.name ? 'border-red-500' : 'border-gray-300' %>">
            
            <% if (errors?.name) { %>
                <p class="text-red-500 text-sm mt-1"><%= errors.name %></p>
            <% } %>
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700">Description:</label>
            <textarea 
                name="description" 
                rows="3"
                class="mt-1 block w-full px-3 py-2 border rounded-md shadow-sm focus:outline-none 
                <%= errors?.description ? 'border-red-500' : 'border-gray-300' %>"><%= old?.description || '' %></textarea>
            
            <% if (errors?.description) { %>
                <p class="text-red-500 text-sm mt-1"><%= errors.description %></p>
            <% } %>
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700">Price:</label>
            <input 
                type="text" 
                name="price" 
                value="<%= old?.price || '' %>"
                class="mt-1 block w-full px-3 py-2 border rounded-md shadow-sm focus:outline-none 
                <%= errors?.price ? 'border-red-500' : 'border-gray-300' %>">
            <% if (errors?.price) { %>
                <p class="text-red-500 text-sm mt-1"><%= errors.price %></p>
            <% } %>
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700">Category:</label>
            <select 
                name="category"
                class="mt-1 block w-full px-3 py-2 border rounded-md shadow-sm focus:outline-none 
                <%= errors?.category ? 'border-red-500' : 'border-gray-300' %>">
                <option value="">-- Select Category --</option>
                <option value="Electronics" <%= old?.category === 'Electronics' ? 'selected' : '' %>>Electronics</option>
                <option value="Fashion" <%= old?.category === 'Fashion' ? 'selected' : '' %>>Fashion</option>
                <option value="Home & Living" <%= old?.category === 'Home & Living' ? 'selected' : '' %>>Home & Living</option>
                <option value="Books" <%= old?.category === 'Books' ? 'selected' : '' %>>Books</option>
            </select>

            <% if (errors?.category) { %>
                <p class="text-red-500 text-sm mt-1"><%= errors.category %></p>
            <% } %>
        </div>

        
        <div>
            <label class="block text-sm font-medium text-gray-700">Stock:</label>
            <input 
                type="text" 
                name="stock" 
                value="<%= old?.stock || '' %>"
                class="mt-1 block w-full px-3 py-2 border rounded-md shadow-sm focus:outline-none 
                <%= errors?.stock ? 'border-red-500' : 'border-gray-300' %>">
            
            <% if (errors?.stock) { %>
                <p class="text-red-500 text-sm mt-1"><%= errors.stock %></p>
            <% } %>
        </div>
        <button 
            type="submit" 
            class="w-full bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 focus:outline-none">
            Add Product
        </button>

    </form>
</div>
</body>
</html>
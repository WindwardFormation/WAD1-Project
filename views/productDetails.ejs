<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
    <div class="container mx-auto px-4 py-8">
        <a href="/products" class="text-indigo-600 hover:text-indigo-800 mb-4 inline-block">&larr; Back to Products</a>
        <div class="bg-white p-8 rounded-lg shadow-md">
            <h1 class="text-3xl font-bold mb-4"><%= product.name %></h1>
            <p class="text-gray-700 mb-4"><%= product.description %></p>
            <p class="text-2xl font-bold text-green-600 mb-2">$<%= product.price %></p>
            <p class="text-gray-600 mb-2">Category: <%= product.category %></p>
            <p class="text-gray-600 mb-2">Stock: <%= product.stock %></p>
            <p class="text-gray-600 mb-6">Vendor: <%= product.vendorId.username %></p>
            <% if (session.userId) { %>
                <form action="/cart/add" method="POST" class="mb-8 flex items-center space-x-4">
                    <input type="hidden" name="productId" value="<%= product._id %>">
                    <label class="text-sm font-medium text-gray-700">Quantity:</label>
                    <input type="number" name="quantity" value="1" min="1" max="<%= product.stock %>" class="w-20 px-3 py-2 border border-gray-300 rounded-md">
                    <button type="submit" class="bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700">Add to Cart</button>
                </form>

                <% if (canReview) { %>
                <div class="border-t pt-6">
                    <h2 class="text-2xl font-bold mb-4">Leave a Review</h2>

                    <form action="/reviews/add" method="POST" class="space-y-4">
                        <input type="hidden" name="productId" value="<%= product._id %>">
                        <div>
                            <label class="block text-sm font-medium text-gray-700">Rating:</label>
                            <select name="rating" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md">
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="3">3</option>
                                <option value="4">4</option>
                                <option value="5">5</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700">Comment:</label>
                            <textarea name="comment" rows="4" required class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md"></textarea>
                        </div>
                        <button type="submit" class="bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700">
                            Submit Review
                        </button>
                    </form>

                </div>
                <% } %>
            <% } %>
            
            <div class="border-t pt-6 mt-6">
                <h2 class="text-2xl font-bold mb-4">Reviews (<%= reviews.length %>)</h2>
                <% if (message === 'created') { %>
                    <p class="text-green-600 mb-4">Review created successfully!</p>
                <% } %>

                <% if (message === 'updated') { %>
                    <p class="text-green-600 mb-4">Review updated successfully!</p>
                <% } %>

                <% if (message === 'deleted') { %>
                    <p class="text-green-600 mb-4">Review deleted successfully!</p>
                <% } %>


                <% if (message === 'invalid_rating') { %>
                    <p class="text-red-600 mb-4">Rating must be between 1 and 5.</p>
                <% } %>

                <% if (message === 'empty_comment') { %>
                    <p class="text-red-600 mb-4">Comment cannot be empty.</p>
                <% } %>

                <% if (message === 'not_allowed') { %>
                    <p class="text-red-600 mb-4">You can only review products you have purchased.</p>
                <% } %>

                <% if (message === 'already_reviewed') { %>
                    <p class="text-red-600 mb-4">You have already reviewed this product.</p>
                <% } %>

                <% if (message === 'no_changes') { %>
                    <p class="text-red-600 mb-4">No changes detected.</p>
                <% } %>
                

                <% if (!reviews || reviews.length === 0) { %>
                <p class="text-gray-500">No reviews yet</p>
                <% } else { %>
                    <% reviews.forEach(review => { %>
                        <div class="bg-gray-50 p-4 rounded-md mb-4">
                            <p class="font-semibold"><%= review.username%> - <span class="text-yellow-500"><%= '★'.repeat(review.rating) %></span> (<%= review.rating %>/5)</p>
                            <p class="text-gray-700"><%= review.comment %></p>
                            <br>
                            <p class="text-sm text-gray-500">
                                <%= review.createdAt.toDateString() %>
                            </p>
                            <br>
                            
                            <!--check if user is logged in and if review belongs to user-->
                            <% if (session.userId && review.userId && review.userId.toString() === session.userId) { %>
                                <div class="mt-2 space-x-2">
                                    
                                    <form action="/reviews/update/<%= review._id %>" method="POST" class="inline">
                                        <input type="hidden" name="productId" value="<%= product._id %>">
                                        <label class="block text-sm font-medium text-gray-700">Rating:</label>
                                        <select name="rating" class="px-2 py-1 border border-gray-300 rounded">
                                            <option value="1" <%= review.rating === 1 ? 'selected' : '' %>>1</option>
                                            <option value="2" <%= review.rating === 2 ? 'selected' : '' %>>2</option>
                                            <option value="3" <%= review.rating === 3 ? 'selected' : '' %>>3</option>
                                            <option value="4" <%= review.rating === 4 ? 'selected' : '' %>>4</option>
                                            <option value="5" <%= review.rating === 5 ? 'selected' : '' %>>5</option>
                                        </select>
                                        <br>
                                        <label class="block text-sm font-medium text-gray-700">Comment:</label>
                                        <textarea name="comment" rows="2" class="px-2 py-1 border border-gray-300 rounded"><%= review.comment %></textarea>
                                        <br>
                                        <button type="submit" onclick="return confirm('Are you sure you want to update this review?')" class="bg-blue-500 text-white px-3 py-1 rounded hover:bg-blue-600">
                                            Update
                                        </button>
                                    </form>
                                    
                                    <form action="/reviews/delete/<%= review._id %>" method="POST" class="inline">
                                        <button type="submit" onclick="return confirm('Are you sure you want to delete this review?')" class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            <% } %>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>